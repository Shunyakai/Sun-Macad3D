<panels:PropertyPanel x:Class="Macad.Interaction.Editors.Auxiliary.AnnotationLabelPropertyPanel"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                      xmlns:panels="clr-namespace:Macad.Interaction.Panels"
                      xmlns:mmp="clr-namespace:Macad.Presentation;assembly=Macad.Presentation"
                      xmlns:local="clr-namespace:Macad.Interaction.Editors.Auxiliary"
                      mc:Ignorable="d" 
                      DataContext="{Binding RelativeSource={RelativeSource Self}}" 
                      Style="{DynamicResource Macad.Styles.PropertyPanel}"
                      Header="Annotation Label">

    <StackPanel>
        <!-- Interactive -->
        <panels:InteractivePropertyGroup Entity="{Binding AnnotationLabel}" />

        <!-- Transformable -->
        <panels:TransformablePropertyGroup Transformable="{Binding AnnotationLabel}" />

        <Grid Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Text Content -->
            <TextBlock Grid.Row="0" Grid.Column="0" 
                       Text="Text" 
                       Style="{StaticResource Macad.Styles.TextBlock.Property}" />
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding AnnotationLabel.Text, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,4,0,4"
                     AutomationProperties.AutomationId="AnnotationLabelText"/>

            <!-- Has Leader Line -->
            <TextBlock Grid.Row="1" Grid.Column="0" 
                       Text="Leader Line" 
                       Style="{StaticResource Macad.Styles.TextBlock.Property}" />
            <CheckBox Grid.Row="1" Grid.Column="1"
                      Margin="0,4,0,4"
                      VerticalAlignment="Center" HorizontalAlignment="Left"
                      IsChecked="{Binding AnnotationLabel.HasLeader, NotifyOnSourceUpdated=True}"
                      AutomationProperties.AutomationId="HasLeader"/>
        </Grid>
    </StackPanel>

</panels:PropertyPanel>
