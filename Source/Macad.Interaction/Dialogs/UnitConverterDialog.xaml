<mmp:Dialog x:Class="Macad.Interaction.Dialogs.UnitConverterDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mmp="clr-namespace:Macad.Presentation;assembly=Macad.Presentation"
             mc:Ignorable="d" 
             Title="Units Converter"
             ResizeMode="NoResize" 
             ShowInTaskbar="False" 
             Width="380" Height="280"
             Padding="20"
             SizeToContent="Manual"
             Style="{StaticResource {x:Type mmp:Dialog}}"
             DataContext="{Binding RelativeSource={RelativeSource Self}}">
    
    <mmp:Dialog.Footer>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" IsDefault="True" IsCancel="True" 
                    Style="{StaticResource Macad.Styles.Button.DialogFooter}" 
                    AutomationProperties.AutomationId="CloseBtn" />
        </StackPanel>
    </mmp:Dialog.Footer>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Category Selector -->
        <Label Grid.Row="0" Grid.Column="0" Content="Category:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="0" Grid.Column="1" 
                  ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                  Margin="5" Height="28" VerticalContentAlignment="Center"/>

        <!-- Input Value & Unit -->
        <Label Grid.Row="1" Grid.Column="0" Content="From:" VerticalAlignment="Center" Margin="5"/>
        <Grid Grid.Row="1" Grid.Column="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" 
                     Height="28" Margin="0,0,5,0" VerticalContentAlignment="Center"/>
            <ComboBox Grid.Column="1" 
                      ItemsSource="{Binding AvailableUnits}"
                      SelectedItem="{Binding FromUnit, Mode=TwoWay}"
                      Height="28" VerticalContentAlignment="Center"/>
        </Grid>

        <!-- Target Unit & Result -->
        <Label Grid.Row="2" Grid.Column="0" Content="To:" VerticalAlignment="Center" Margin="5"/>
        <Grid Grid.Row="2" Grid.Column="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding OutputText, Mode=OneWay}" 
                     IsReadOnly="True" Background="#F0F0F0"
                     Height="28" Margin="0,0,5,0" VerticalContentAlignment="Center"/>
            <ComboBox Grid.Column="1" 
                      ItemsSource="{Binding AvailableUnits}"
                      SelectedItem="{Binding ToUnit, Mode=TwoWay}"
                      Height="28" VerticalContentAlignment="Center"/>
        </Grid>
        
        <!-- Quick Swap Button -->
        <Button Grid.Row="3" Grid.Column="1" Content="Swap Units" 
                Click="SwapUnits_Click" Width="100" HorizontalAlignment="Left" Margin="5" Height="24"/>
    </Grid>
</mmp:Dialog>
