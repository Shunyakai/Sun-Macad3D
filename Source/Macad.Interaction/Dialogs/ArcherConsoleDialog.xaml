<mmp:Dialog x:Class="Macad.Interaction.Dialogs.ArcherConsoleDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mmp="clr-namespace:Macad.Presentation;assembly=Macad.Presentation"
             mc:Ignorable="d" 
             Title="BRL-CAD Archer Console"
             ResizeMode="CanResize" 
             ShowInTaskbar="False" 
             Width="500" Height="400"
             MinWidth="400" MinHeight="300"
             Style="{StaticResource {x:Type mmp:Dialog}}"
             DataContext="{Binding RelativeSource={RelativeSource Self}}">
    
    <mmp:Dialog.Footer>
        <DockPanel LastChildFill="False">
            <Button DockPanel.Dock="Right" Content="Close" IsCancel="True" Click="Close_Click"
                    Style="{StaticResource Macad.Styles.Button.DialogFooter}" />
        </DockPanel>
    </mmp:Dialog.Footer>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Modeless terminal log screen -->
        <TextBox Grid.Row="0" x:Name="ConsoleLog"
                 Background="#1E1E1E" Foreground="#00FF00" FontFamily="Consolas" FontSize="12"
                 IsReadOnly="True" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                 BorderThickness="0" Margin="10,10,10,5" Padding="5"/>

        <!-- Command Input Field -->
        <Grid Grid.Row="1" Margin="10,5,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="archer> " Foreground="#00FF00" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Grid.Column="1" x:Name="InputBox"
                     Background="#2D2D2D" Foreground="#00FF00" FontFamily="Consolas" FontSize="12"
                     BorderBrush="#00FF00" BorderThickness="1" Height="28" Padding="5,2"
                     KeyDown="InputBox_KeyDown" VerticalContentAlignment="Center"/>
        </Grid>
    </Grid>
</mmp:Dialog>
