<mmp:Dialog x:Class="Macad.Interaction.Dialogs.PrintPreviewDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mmp="clr-namespace:Macad.Presentation;assembly=Macad.Presentation"
             mc:Ignorable="d" 
             Title="Print Preview"
             ResizeMode="CanResize" 
             ShowInTaskbar="False" 
             Width="850" Height="650"
             MinWidth="600" MinHeight="500"
             Style="{StaticResource {x:Type mmp:Dialog}}"
             DataContext="{Binding RelativeSource={RelativeSource Self}}">
    
    <mmp:Dialog.Footer>
        <DockPanel LastChildFill="False">
            <Button DockPanel.Dock="Right" Content="Close" IsCancel="True" Click="Close_Click"
                    Style="{StaticResource Macad.Styles.Button.DialogFooter}" />
            <Button DockPanel.Dock="Right" Content="Print..." Click="Print_Click"
                    Style="{StaticResource Macad.Styles.Button.DialogFooter}" Margin="0,0,10,0" />
        </DockPanel>
    </mmp:Dialog.Footer>

    <Grid Background="#E5E5E5">
        <DocumentViewer x:Name="DocViewer" ShowPageBorders="True" Focusable="False"/>
    </Grid>
</mmp:Dialog>
