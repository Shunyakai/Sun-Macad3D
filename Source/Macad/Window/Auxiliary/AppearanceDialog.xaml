<mmp:Dialog x:Class="Macad.Window.AppearanceDialog"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
            xmlns:mmp="clr-namespace:Macad.Presentation;assembly=Macad.Presentation"
            mc:Ignorable="d" 
            Style="{StaticResource {x:Type mmp:Dialog}}"
            DataContext="{Binding RelativeSource={RelativeSource Self}}"        
            Title="Appearance Settings"
            Height="Auto" Width="360"
            SizeToContent="Height"
            WindowStartupLocation="CenterOwner"
            AutomationProperties.AutomationId="AppearanceDialog">

    <mmp:Dialog.Footer>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True" Click="OkBtn_Click"
                    Style="{StaticResource Macad.Styles.Button.DialogFooter}"
                    Width="80" Margin="0,0,10,0"
                    AutomationProperties.AutomationId="OkBtn"/>
            <Button Content="Cancel" IsCancel="True" Click="CancelBtn_Click"
                    Style="{StaticResource Macad.Styles.Button.DialogFooter}"
                    Width="80"
                    AutomationProperties.AutomationId="CancelBtn"/>
        </StackPanel>
    </mmp:Dialog.Footer>

    <Grid Margin="15,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Target Label -->
        <TextBlock Grid.Row="0" x:Name="TargetLabel" Text="Editing:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15" Foreground="{StaticResource Macad.Brushes.Text}"/>

        <!-- Color Row -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Content="Color:" VerticalAlignment="Center" Foreground="{StaticResource Macad.Brushes.Text}"/>
            <ComboBox Grid.Column="1" x:Name="ColorCombo" Height="25"
                      SelectionChanged="ColorCombo_SelectionChanged"
                      AutomationProperties.AutomationId="ColorCombo"/>
        </Grid>

        <!-- Transparency Row -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <Label Content="Transparency:" VerticalAlignment="Center" Foreground="{StaticResource Macad.Brushes.Text}"/>
            <Slider Grid.Column="1" x:Name="TransparencySlider" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                    ValueChanged="TransparencySlider_ValueChanged"
                    AutomationProperties.AutomationId="TransparencySlider"/>
            <TextBlock Grid.Column="2" x:Name="TransparencyValueText" Text="0%" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{StaticResource Macad.Brushes.Text}"/>
        </Grid>

        <!-- Material Row -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Content="Material:" VerticalAlignment="Center" Foreground="{StaticResource Macad.Brushes.Text}"/>
            <ComboBox Grid.Column="1" x:Name="MaterialCombo" Height="25"
                      AutomationProperties.AutomationId="MaterialCombo"/>
        </Grid>

        <!-- Reset Button -->
        <Button Grid.Row="4" x:Name="ResetBtn" Content="Reset to Default" HorizontalAlignment="Left" Width="120" Height="25" Click="ResetBtn_Click"
                AutomationProperties.AutomationId="ResetBtn"/>
    </Grid>

</mmp:Dialog>
