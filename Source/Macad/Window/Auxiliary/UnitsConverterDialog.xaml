<mmp:Dialog x:Class="Macad.Window.UnitsConverterDialog"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
            xmlns:mmp="clr-namespace:Macad.Presentation;assembly=Macad.Presentation"
            mc:Ignorable="d" 
            Style="{StaticResource {x:Type mmp:Dialog}}"
            DataContext="{Binding RelativeSource={RelativeSource Self}}"        
            Title="Units Converter"
            Height="Auto" Width="420"
            SizeToContent="Height"
            WindowStartupLocation="CenterOwner"
            AutomationProperties.AutomationId="UnitsConverterDialog">

    <mmp:Dialog.Footer>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Close" IsCancel="True"
                    Style="{StaticResource Macad.Styles.Button.DialogFooter}"
                    AutomationProperties.AutomationId="CloseBtn"/>
        </StackPanel>
    </mmp:Dialog.Footer>

    <Grid Margin="15,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Category Row -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Content="Category:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox Grid.Column="1" x:Name="CategoryCombo"
                      SelectionChanged="CategoryCombo_SelectionChanged"
                      AutomationProperties.AutomationId="CategoryCombo"/>
        </Grid>

        <!-- Convert Row -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- From Unit Group -->
            <StackPanel Grid.Column="0">
                <Label Content="From Value:" Margin="0,0,0,5"/>
                <TextBox x:Name="InputBox" Height="25" Margin="0,0,0,8"
                         TextChanged="InputBox_TextChanged"
                         AutomationProperties.AutomationId="InputBox"/>
                <ComboBox x:Name="FromUnitCombo" Height="25"
                          SelectionChanged="FromUnitCombo_SelectionChanged"
                          AutomationProperties.AutomationId="FromUnitCombo"/>
            </StackPanel>

            <!-- Swap Column -->
            <Button Grid.Column="1" x:Name="SwapBtn" Content="⇄" FontSize="18" FontWeight="Bold"
                    Width="30" Height="30" Margin="10,25,10,0" VerticalAlignment="Center"
                    Click="SwapBtn_Click"
                    AutomationProperties.AutomationId="SwapBtn"/>

            <!-- To Unit Group -->
            <StackPanel Grid.Column="2">
                <Label Content="To Value:" Margin="0,0,0,5"/>
                <TextBox x:Name="ResultBox" Height="25" Margin="0,0,0,8" IsReadOnly="True"
                         Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46"
                         AutomationProperties.AutomationId="ResultBox"/>
                <ComboBox x:Name="ToUnitCombo" Height="25"
                          SelectionChanged="ToUnitCombo_SelectionChanged"
                          AutomationProperties.AutomationId="ToUnitCombo"/>
            </StackPanel>
        </Grid>

        <!-- Action Row -->
        <Grid Grid.Row="2" HorizontalAlignment="Right">
            <Button x:Name="CopyBtn" Content="Copy Result" Width="100" Height="28"
                    Click="CopyBtn_Click"
                    AutomationProperties.AutomationId="CopyBtn"/>
        </Grid>
    </Grid>

</mmp:Dialog>
